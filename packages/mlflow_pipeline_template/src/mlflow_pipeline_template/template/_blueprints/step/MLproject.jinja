name: {{ step_name }}
conda_env: conda.yml

entry_points:
  main:
    parameters:
{% for arg_name, arg_cfg in arguments.items() %}
{% set mlflow_type = {'str': 'string', 'int': 'string', 'float': 'string', 'bool': 'string'}.get(arg_cfg.get('type', 'str'), 'string') %}
      {{ arg_name }}:
        description: "{{ arg_cfg.get('description', '') }}"
        type: {{ mlflow_type }}
{% if not arg_cfg.get('required', false) %}
        default: "{{ arg_cfg.get('default', '') }}"
{% endif %}
{% endfor %}
{% if not arguments %}
      input_artifact:
        description: "Input artifact reference"
        type: string
      output_artifact:
        description: "Output artifact name"
        type: string
{% endif %}

    command: >-
      python run.py
{% for arg_name in arguments.keys() %}
        --{{ arg_name }} {{ '{' }}{{ arg_name }}{{ '}' }}
{% endfor %}
{% if not arguments %}
        --input_artifact {input_artifact}
        --output_artifact {output_artifact}
{% endif %}

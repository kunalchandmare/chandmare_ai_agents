name: {{ step_name }}
conda_env: conda.yml

entry_points:
  main:
    parameters:
      input_artifact:
        description: "Input artifact reference"
        type: string
      output_artifact:
        description: "Output artifact name"
        type: string
      output_type:
        description: "Output artifact type tag"
        type: string
      output_description:
        description: "Output artifact description"
        type: string
      # TODO: add component-specific parameters here

    command: >-
      python run.py
        --input_artifact {input_artifact}
        --output_artifact {output_artifact}
        --output_type {output_type}
        --output_description {output_description}
